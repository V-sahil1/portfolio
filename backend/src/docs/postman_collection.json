{
  "info": {
    "name": "Portfolio Analytics API",
    "description": "Full collection for the portfolio analytics backend. Set {{baseUrl}} (e.g. http://localhost:4000/api/v1). Logging in auto-saves {{accessToken}} and {{refreshToken}}.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:4000/api/v1" },
    { "key": "accessToken", "value": "" },
    { "key": "refreshToken", "value": "" },
    { "key": "sessionId", "value": "11111111-1111-1111-1111-111111111111" },
    { "key": "visitorId", "value": "" }
  ],
  "item": [
    {
      "name": "System",
      "item": [
        {
          "name": "Health",
          "request": { "method": "GET", "url": "{{baseUrl}}/health" }
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.data && res.data.accessToken) {",
                  "  pm.collectionVariables.set('accessToken', res.data.accessToken);",
                  "  pm.collectionVariables.set('refreshToken', res.data.refreshToken);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@portfolio.local\",\n  \"password\": \"Admin@12345\"\n}"
            }
          }
        },
        {
          "name": "Refresh",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/refresh",
            "body": { "mode": "raw", "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}" }
          }
        },
        {
          "name": "Me",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/auth/me"
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/logout",
            "body": { "mode": "raw", "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}" }
          }
        }
      ]
    },
    {
      "name": "Ingest (public)",
      "item": [
        {
          "name": "Create Visitor",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.data && res.data.visitor) pm.collectionVariables.set('visitorId', res.data.visitor.id);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/visitor",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Jane Recruiter\",\n  \"designation\": \"Tech Recruiter\",\n  \"company\": \"Vercel\",\n  \"email\": \"jane@vercel.com\",\n  \"linkedin\": \"https://linkedin.com/in/jane\"\n}"
            }
          }
        },
        {
          "name": "Create Session",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/session",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"sessionId\": \"{{sessionId}}\",\n  \"visitorId\": \"{{visitorId}}\",\n  \"country\": \"India\",\n  \"city\": \"Surat\",\n  \"browser\": \"Chrome\",\n  \"operatingSystem\": \"Windows\",\n  \"deviceType\": \"desktop\",\n  \"landingPage\": \"/\",\n  \"referrer\": \"https://google.com\",\n  \"visitDuration\": 120\n}"
            }
          }
        },
        {
          "name": "Track Event",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/event",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"action\": \"DOWNLOAD_RESUME\",\n  \"visitorId\": \"{{visitorId}}\",\n  \"sessionId\": \"{{sessionId}}\",\n  \"page\": \"/\",\n  \"metadata\": { \"source\": \"hero\" }\n}"
            }
          }
        },
        {
          "name": "Submit Contact",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/contact",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Jane Recruiter\",\n  \"email\": \"jane@vercel.com\",\n  \"company\": \"Vercel\",\n  \"message\": \"We have a backend role that fits your profile.\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Admin (protected)",
      "item": [
        {
          "name": "Dashboard",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/dashboard"
          }
        },
        {
          "name": "List Visitors",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/visitors?page=1&limit=10&sortBy=createdAt&order=DESC"
          }
        },
        {
          "name": "Get Visitor by id",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/visitor/{{visitorId}}"
          }
        },
        {
          "name": "Analytics Report",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/analytics?limit=5"
          }
        },
        {
          "name": "Search Visitors",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/analytics/search?company=Vercel&country=India"
          }
        }
      ]
    }
  ]
}
